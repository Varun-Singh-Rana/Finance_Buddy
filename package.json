{
  "name": "Finlytics",
  "version": "2.0.0",
  "description": "Personal finance insights, budgeting, and forecasting assistant.",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Varun-Singh-Rana/Finance_Buddy.git"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^26.8.1"
  },
  "author": "Varun Singh Rana",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Varun-Singh-Rana/Finance_Buddy/issues"
  },
  "homepage": "https://github.com/Varun-Singh-Rana/Finance_Buddy#readme",
  "build": {
    "appId": "com.finlytics.app",
    "productName": "Finlytics",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "src/assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/Finlytics_logo.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/Finlytics_logo.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/Finlytics_logo.png"
    }
  }
}
